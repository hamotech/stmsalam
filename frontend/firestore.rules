rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Categories: public read, authenticated admin write
    match /categories/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Products: public read, authenticated admin write
    match /products/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Gallery: public read, authenticated admin write
    match /gallery/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders: 
    //  - Anyone can create (place order)
    //  - Anyone can read (for live tracking)
    //  - Only authenticated admins can update status or delete
    match /orders/{docId} {
      allow create, read: if true;
      allow update, delete: if request.auth != null;
    }
    
    // Global lock for other collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
