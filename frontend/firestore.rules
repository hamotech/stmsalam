rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "admin@stm.com";
    }

    // Categories: public read, authenticated admin write
    match /categories/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Products: public read, authenticated admin write
    match /products/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Gallery: public read, authenticated admin write
    match /gallery/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Orders: 
    //  - Anyone can create (place order)
    //  - Anyone can read (for live tracking)
    //  - Only authenticated admins can update status or delete
    match /orders/{docId} {
      allow create, read: if true;
      allow update, delete: if isAdmin();
    }
    
    // Global lock for other collections
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
