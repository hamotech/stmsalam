rules_version = '2';

// STM Salam Teh Tarik - Firebase Storage Rules
service firebase.storage {
  match /b/{bucket}/o {
    
    // 1. PRODUCT IMAGES
    // Allow public read so customers can see the menu images
    // Allow write access only for authenticated admins
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. USER CONTENT (if any)
    // Only the owner can manage their own folder
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 3. DEFAULT RULES
    // Deny everything else by default for security
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
