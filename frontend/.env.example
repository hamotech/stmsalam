# Copy to .env.local and fill in. Vite exposes only VITE_* vars to the client.

# Firebase (required for checkout + tracking) — project: teh-tarik-app-my-own (#239722784519)
# Get API key + app id from Firebase Console → Project settings → Your apps (Web).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=teh-tarik-app-my-own.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=teh-tarik-app-my-own
# Use either .appspot.com or .firebasestorage.app (Console shows the default bucket name).
VITE_FIREBASE_STORAGE_BUCKET=teh-tarik-app-my-own.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=239722784519
VITE_FIREBASE_APP_ID=

# Callable region (must match deployed Cloud Functions)
VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Optional: REST base for admin/other features — NOT used for customer checkout (Firebase callable only).
# VITE_API_URL=

# Google Maps — Geocoding for delivery distance on checkout (restrict key by HTTP referrer)
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=

# Stripe — customer checkout: src/services/stripeCheckout.js (fixed Cloud Run URL) + callable createStripePendingOrder only.
# Optional: REST base for OrderTracking.jsx POST /verify-checkout-session only (not checkout creation).
VITE_STRIPE_CHECKOUT_API=

# Optional: if STRIPE_VERIFY_BEARER_TOKEN is set on the server, set the same value here
# so /tracking can call POST /verify-checkout-session after redirect.
VITE_STRIPE_VERIFY_BEARER_TOKEN=

# Optional: legacy demo / custom redirect URL for Stripe (see Checkout.jsx)
# VITE_STRIPE_CHECKOUT_URL=

# Firebase Functions: set secrets with `firebase functions:secrets:set STRIPE_SECRET_KEY`
# and `… STRIPE_WEBHOOK_SECRET` (Secret Manager only — do not put these in any .env file).
# Stripe Dashboard → Developers → Webhooks → paste your deployed `stripeWebhook` HTTPS URL (Console / Firebase shows Gen2 URL).

# Optional: production PayPal redirect base URL
# VITE_PAYPAL_CHECKOUT_URL=
