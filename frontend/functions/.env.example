# Firebase Functions (this folder) — do NOT put Stripe API keys or webhook secrets here.
# Stripe: use Secret Manager + defineSecret().value() only (see stripeCheckoutHttp.js).
#
# Stripe Checkout redirect base (must match your Vite origin in dev). Examples:
# STRIPE_PUBLIC_BASE_URL=http://localhost:5173
# STRIPE_PUBLIC_BASE_URL=https://your-domain.web.app
