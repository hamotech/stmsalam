# Firebase (required for app)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# HitPay (Scan & Pay) — use sandbox base while testing
# Maps app expectation HITPAY_API_KEY → EXPO_PUBLIC_HITPAY_API_KEY (Expo exposes EXPO_PUBLIC_* only)
EXPO_PUBLIC_HITPAY_API_KEY=
EXPO_PUBLIC_HITPAY_API_BASE=https://api.sandbox.hit-pay.com

# Stripe — publishable key + backend that returns PaymentSheet secrets
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# POST JSON { "orderId": string, "amount": number } → { "paymentIntent", "ephemeralKey", "customer" }
EXPO_PUBLIC_STRIPE_PAYMENT_SHEET_ENDPOINT=
