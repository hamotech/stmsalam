# Copy to .env for local non-Firebase secrets only.
# Firebase (apiKey, projectId, appId, etc.) is locked in src/services/firebase.ts — do not use EXPO_PUBLIC_FIREBASE_*.
#
# Expo: `npm run start` / `start:8082` set EXPO_NO_DEPENDENCY_VALIDATION=1 (works around flaky Expo API fetch on some setups). For tunnel/dev client, same scripts keep online features except that one doctor step.

# Alternate app entry: repo-root `src_v2` (default off — use production Expo Router app)
# EXPO_PUBLIC_USE_NEW_APP=true

# Admin RBAC: after Firestore users have role "admin" and rules are deployed, set true (role-only, no legacy isAdmin)
# EXPO_PUBLIC_ADMIN_AUTH_STRICT_ROLE_ONLY=true

# Dev-only (__DEV__): skip admin sign-in and open `/admin` index directly (Firestore rules still apply)
# EXPO_PUBLIC_ADMIN_AUTH_BYPASS=true

# Optional: HTTPS continue URL for password reset emails (must be an Authorized domain in Firebase Console).
# EXPO_PUBLIC_PASSWORD_RESET_CONTINUE_URL=https://yourdomain.com/reset-password

# HitPay (Scan & Pay) — use sandbox base while testing
# Maps app expectation HITPAY_API_KEY → EXPO_PUBLIC_HITPAY_API_KEY (Expo exposes EXPO_PUBLIC_* only)
EXPO_PUBLIC_HITPAY_API_KEY=
EXPO_PUBLIC_HITPAY_API_BASE=https://api.sandbox.hit-pay.com

# Google Maps — Places Autocomplete + Geocoding for delivery address (optional; falls back to OpenStreetMap)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Stripe — publishable key + backend that returns PaymentSheet secrets
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# POST { "orderId", "amount" } → { "paymentIntent", "ephemeralKey", "customer", "paymentIntentId" }
# Run: cd stm-mobile/server && node stripe-express-server.mjs  (default :8788)
EXPO_PUBLIC_STRIPE_PAYMENT_SHEET_ENDPOINT=http://127.0.0.1:8788/payment-sheet
# POST { "orderId", "paymentIntentId" } → { "ok": true } after Stripe + Firestore (required before success UI)
EXPO_PUBLIC_STRIPE_VERIFY_PAYMENT_ENDPOINT=http://127.0.0.1:8788/verify-payment
# Optional; must match server STRIPE_VERIFY_BEARER_TOKEN if set
# EXPO_PUBLIC_STRIPE_VERIFY_BEARER_TOKEN=

# QR — customer "I have paid" (server writes orders.qrCustomerClaimedAt; admin sets PAID)
EXPO_PUBLIC_QR_CLAIM_PAYMENT_ENDPOINT=http://127.0.0.1:8788/qr-claim-payment
# Optional; defaults to EXPO_PUBLIC_STRIPE_VERIFY_BEARER_TOKEN, or server QR_CLAIM_BEARER_TOKEN
# EXPO_PUBLIC_QR_CLAIM_BEARER_TOKEN=
