{
  "cli": {
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk",
        "resourceClass": "medium"
      },
      "ios": {
        "simulator": false,
        "resourceClass": "medium"
      },
      "env": {
        "NODE_OPTIONS": "--dns-result-order=ipv4first"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle",
        "resourceClass": "large"
      },
      "ios": {
        "simulator": false,
        "resourceClass": "large"
      },
      "env": {
        "NODE_OPTIONS": "--dns-result-order=ipv4first"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
